{
  "expo": {
    "name": "thirty",
    "slug": "thirty",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a12"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "14",
      "bundleIdentifier": "com.thirty.app",
      "appleTeamId": "B2MV35NY53",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.thirty.app"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "thirty uses HealthKit to log your mindful minutes.",
        "NSHealthUpdateUsageDescription": "thirty logs your meditation sessions as mindful minutes in Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a12",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.thirty.app"
    },
    "plugins": [
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "86800fd2-09c9-4b9d-87d0-66ba35c240a1"
      }
    },
    "owner": "sethlouis"
  }
}